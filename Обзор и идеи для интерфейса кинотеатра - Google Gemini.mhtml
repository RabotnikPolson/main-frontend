    <script>
        const sliderContainer = document.getElementById('slider-container');
        const btnLeft = document.getElementById('slider-left');
        const btnRight = document.getElementById('slider-right');
        
        btnRight.addEventListener('click', () => {
            sliderContainer.scrollBy({ left: 300, behavior: 'smooth' });
        });

        btnLeft.addEventListener('click', () => {
            sliderContainer.scrollBy({ left: -300, behavior: 'smooth' });
        });

        window.addEventListener('scroll', () => {
            const nav = document.querySelector('nav');
            if (window.scrollY > 50) {
                nav.classList.add('shadow-lg');
                nav.classList.replace('glass-nav', 'bg-slate-900/95');
            } else {
                nav.classList.remove('shadow-lg');
                nav.classList.replace('bg-slate-900/95', 'glass-nav');
            }
        });
    </script>
